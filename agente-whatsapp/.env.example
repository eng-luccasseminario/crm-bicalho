# ==============================================================================
#  CRM Bicalho — Agente IA · variáveis de ambiente
#  Copie este arquivo para `.env` e preencha. NUNCA commite o `.env` real.
#  Guia completo de onde pegar cada credencial: ../docs/SETUP.md
# ==============================================================================

# --- Canal de conversa ativo -------------------------------------------------
# telegram (padrão) | whatsapp (Meta Cloud API) | evolution (legado)
CANAL=telegram

# --- OpenAI (cérebro do agente: GPT-4o + Whisper) ----------------------------
# Pegue em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Twenty CRM --------------------------------------------------------------
# TWENTY_API_URL = URL do seu Twenty no Railway
# TWENTY_API_KEY = dentro do Twenty: Settings > APIs & Webhooks > gerar API Key
TWENTY_API_URL=https://seu-twenty.up.railway.app
TWENTY_API_KEY=sua_chave_twenty

# --- Google (Drive = CDE de documentos + Calendar = reuniões) ----------------
# 1) console.cloud.google.com > APIs & Services > Credentials > OAuth Client (Web)
# 2) Ative as APIs "Google Drive API" e "Google Calendar API"
# 3) Gere o REFRESH_TOKEN rodando:  npx ts-node src/google-auth.ts  (ou o conector)
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3999/oauth2callback
GOOGLE_REFRESH_TOKEN=gerado_pelo_google-auth

# --- Telegram (canal padrão) -------------------------------------------------
# Crie o bot com o @BotFather e cole o token aqui.
# TELEGRAM_ALLOWED_CHAT_IDS: opcional, IDs separados por vírgula (vazio = libera todos)
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_ALLOWED_CHAT_IDS=

# --- WhatsApp Business Cloud API (canal oficial, opcional) -------------------
# Só necessário se CANAL=whatsapp. Config em developers.facebook.com (ver docs/ATIVAR-WHATSAPP.md)
#   WHATSAPP_VERIFY_TOKEN: string que você inventa (usada no webhook)
#   WHATSAPP_ALLOWED: opcional, números autorizados separados por vírgula
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ALLOWED=

# --- Evolution API (WhatsApp não-oficial / Baileys — LEGADO, pausado) --------
# Mantido só por compatibilidade. Preferir o WhatsApp Cloud oficial acima.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=seminario

# --- Servidor (usado pelos canais com webhook: whatsapp/evolution) -----------
PORT=3002
